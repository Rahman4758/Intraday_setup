# ──── Upstox API ────
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ──── MongoDB ────
MONGODB_URI=mongodb://localhost:27017/antigravity-pil

# ──── Server ────
PORT=3000
NODE_ENV=development

# ──── PIL Config ────
PIL_MAX_STOCKS=10
PIL_RSI_LOOKBACK=14
PIL_VOLUME_AVG_DAYS=20
PIL_NIFTY_INSTRUMENT_KEY=NSE_INDEX|Nifty 50
